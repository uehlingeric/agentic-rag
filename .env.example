# Copy to .env and fill in the providers you use. Never commit .env.
# The Ollama path needs no keys at all.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional overrides (defaults shown)
# AGENTIC_RAG_PROVIDER=ollama
# AGENTIC_RAG_OLLAMA__HOST=http://localhost:11434

# Required for `agentic-rag serve` (any static string; the compose stack
# defaults to local-dev-token)
# AGENTIC_RAG_API__TOKEN=

# Bedrock/Vertex backends need no keys here: anthropic can route via AWS Bedrock
# (aws CLI credential chain) and google via Vertex AI (gcloud ADC). See config.yaml.
# AGENTIC_RAG_ANTHROPIC__BACKEND=bedrock
# AGENTIC_RAG_GOOGLE__BACKEND=vertex
